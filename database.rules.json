{
  "rules": {
    "householdMembers": {
      "$uid": {
        ".read":  "auth != null && $uid === auth.uid",
        ".write": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && $uid === auth.uid"
      }
    },
    "households": {
      "$code": {
        "meta": {
          ".read":  "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous'",
          ".write": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('householdMembers/' + auth.uid + '/code').val() === $code"
        },
        "members": {
          ".read":  "auth != null && root.child('householdMembers/' + auth.uid + '/code').val() === $code",
          "$uid": {
            ".write": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && ($uid === auth.uid || root.child('householdMembers/' + auth.uid + '/code').val() === $code)"
          }
        },
        "data": {
          ".read":  "auth != null && root.child('householdMembers/' + auth.uid + '/code').val() === $code",
          ".write": "auth != null && auth.token.firebase.sign_in_provider !== 'anonymous' && root.child('householdMembers/' + auth.uid + '/code').val() === $code"
        }
      }
    }
  }
}
